            </constraints>
            <properties>
              <text value="Font:"/>
            </properties>
          </component>
          <component id="4a2db" class="javax.swing.JComboBox" binding="fontBox">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <model>
                <item value="Arial"/>
