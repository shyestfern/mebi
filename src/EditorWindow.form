            </constraints>
            <properties>
              <horizontalScrollBarPolicy value="30"/>
              <verticalScrollBarPolicy value="20"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="a3d50" class="javax.swing.JTextArea" binding="textArea">
                <constraints/>
                <properties>
                  <columns value="0"/>
                  <rows value="0"/>
                </properties>
              </component>
            </children>
          </scrollpane>
        </children>
      </grid>
      <component id="ecf56" class="javax.swing.JLabel" binding="statusBar">
