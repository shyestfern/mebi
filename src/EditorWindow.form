        </constraints>
        <properties>
          <text value="Žádný otevřený soubor"/>
        </properties>
      </component>
      <grid id="b9cf" binding="toolbarPanel" layout-manager="GridLayoutManager" row-count="1" column-count="5" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
